// Test generic struct instantiation and monomorphization

module test_generic_instantiate;

struct Point<T> {
    x: T,
    y: T
}

struct Pair<T, U> {
    first: T,
    second: U
}

fn main() -> int {
    // Test Point<int>
    let p1 = Point<int> { x: 10, y: 20 };
    
    // Test Point<float>
    let p2 = Point<float> { x: 3.14, y: 2.71 };
    
    // Test Pair<int, float>
    let pair = Pair<int, float> { first: 42, second: 1.5 };
    
    return p1.x + p1.y; // Should return 30
}
