// Test generic enum instantiation and monomorphization

module test_generic_enum;

enum Option<T> {
    Some(T),
    None
}

enum Result<T, E> {
    Ok(T),
    Err(E)
}

fn main() -> int {
    // Test Option<int>
    let opt1 = Option<int>::Some(42);
    let opt2 = Option<int>::None;
    
    // Test Option<float>
    let opt3 = Option<float>::Some(3.14);
    
    // Test Result<int, string>
    let res1 = Result<int, string>::Ok(100);
    let res2 = Result<int, string>::Err("error");
    
    return 0;
}
