{
  "name": "spectra-vscode-extension",
  "displayName": "SpectraLang",
  "description": "VS Code support for SpectraLang with diagnostics, formatting, hover, completion, and go-to-definition via LSP.",
  "version": "0.0.1",
  "publisher": "spectralang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Estevaobonatto/SpectraLang"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "icon": "assets/spectra-icon.png",
  "activationEvents": [
    "workspaceContains:**/*.spectra"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "spectra",
        "aliases": ["Spectra", "SpectraLang"],
        "extensions": [".spectra"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/spectra-file-light.png",
          "dark": "./assets/spectra-file-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "spectra",
        "scopeName": "source.spectra",
        "path": "./syntaxes/spectra.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "spectra",
        "path": "./snippets/spectra.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "spectra.diagnostics.run",
        "title": "Spectra: Run Diagnostics for Current File"
      },
      {
        "command": "spectra.lintWorkspace",
        "title": "Spectra: Lint Workspace"
      },
      {
        "command": "spectra.compileCurrentFile",
        "title": "Spectra: Compile Current File"
      },
      {
        "command": "spectra.checkCurrentFile",
        "title": "Spectra: Check Current File",
        "icon": "$(check)"
      },
      {
        "command": "spectra.runCurrentFile",
        "title": "Spectra: Run Current File",
        "icon": "$(play)"
      },
      {
        "command": "spectra.compilerActions",
        "title": "Spectra: Compiler Actions..."
      },
      {
        "command": "spectra.newProject",
        "title": "Spectra: New Project"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "spectra.diagnostics.run",
          "when": "editorLangId == spectra"
        },
        {
          "command": "spectra.lintWorkspace"
        },
        {
          "command": "spectra.compileCurrentFile",
          "when": "editorLangId == spectra"
        },
        {
          "command": "spectra.checkCurrentFile",
          "when": "editorLangId == spectra"
        },
        {
          "command": "spectra.runCurrentFile",
          "when": "editorLangId == spectra"
        },
        {
          "command": "spectra.compilerActions",
          "when": "editorLangId == spectra"
        },
        {
          "command": "spectra.newProject"
        }
      ],
      "editor/title": [
        {
          "command": "spectra.runCurrentFile",
          "when": "editorLangId == spectra",
          "group": "navigation@1"
        },
        {
          "command": "spectra.checkCurrentFile",
          "when": "editorLangId == spectra",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "spectra.runCurrentFile",
        "key": "ctrl+f5",
        "when": "editorLangId == spectra"
      },
      {
        "command": "spectra.checkCurrentFile",
        "key": "ctrl+shift+h",
        "when": "editorLangId == spectra"
      },
      {
        "command": "spectra.compilerActions",
        "key": "ctrl+shift+p",
        "when": "editorLangId == spectra && false"
      }
    ],
    "configuration": {
      "title": "Spectra",
      "properties": {
        "spectra.serverPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to the spectra-lsp executable. When empty, the extension tries local workspace builds before falling back to PATH."
        },
        "spectra.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Spectra CLI executable. When empty, uses the bundled spectra-cli binary (server/spectra-cli.exe) or falls back to workspace builds and PATH."
        },
        "spectra.lintOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Include lint warnings when a Spectra file is saved. Syntax and semantic diagnostics remain active while editing."
        },
        "spectra.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Format Spectra files on save by requesting formatting from the Spectra language server."
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepublishOnly": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/vscode": "^1.93.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
