{
  "scopeName": "source.spectra",
  "name": "SpectraLang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.spectra",
          "begin": "//",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.spectra" }
          },
          "end": "\\n",
          "endCaptures": {
            "0": { "name": "punctuation.terminator.comment.spectra" }
          }
        },
        {
          "name": "comment.block.spectra",
          "begin": "/\\*",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.spectra" }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.spectra" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.spectra",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.spectra" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.spectra" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.spectra",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.spectra",
          "match": "\\b[0-9](?:[0-9_]*[0-9])?(?:\\.[0-9_]+)?(?:[eE][+-]?[0-9_]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.spectra",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.spectra",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.spectra",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.arithmetic.spectra",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.other.spectra",
          "match": "->|=>"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.spectra",
          "match": "\\b(?:if|elif|elseif|else|unless|match|switch|case|cond|while|do|for|foreach|in|of|repeat|until|loop|return|break|continue|yield|goto)\\b"
        },
        {
          "name": "keyword.declaration.spectra",
          "match": "\\b(?:module|import|export|fn|struct|enum|impl|class|trait|let)\\b"
        },
        {
          "name": "storage.modifier.spectra",
          "match": "\\b(?:pub|mut|Self)\\b"
        },
        {
          "name": "constant.language.boolean.spectra",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.spectra",
          "match": "\\b(?:int|float|double|bool|string|void)\\b"
        }
      ]
    }
  }
}
