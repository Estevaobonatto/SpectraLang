// Teste 19: Recursão
module recursion;

fn factorial(n: int) -> int {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

fn fibonacci(n: int) -> int {
    if n <= 1 {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

fn main() -> int {
    let f1 = factorial(5);
    let f2 = fibonacci(6);
    return f1 + f2;
}
