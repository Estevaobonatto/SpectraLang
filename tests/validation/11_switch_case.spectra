// Teste 11: Switch/case
module switch_case;

fn get_day_name(day: int) -> int {
    let result = 0;
    
    switch day {
        case 1 => {
            result = 10;
        }
        case 2 => {
            result = 20;
        }
        case 3 => {
            result = 30;
        }
        case 4 => {
            result = 40;
        }
        case 5 => {
            result = 50;
        }
    }
    
    return result;
}

fn main() -> int {
    return get_day_name(3);
}
