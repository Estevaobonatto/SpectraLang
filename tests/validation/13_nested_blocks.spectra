// Teste 13: Blocos aninhados
module nested_blocks;

fn test_nested() -> int {
    let result = 0;
    
    if true {
        let x = 10;
        while x > 0 {
            if x > 5 {
                result = result + 1;
            } else {
                result = result + 2;
            }
            x = x - 1;
        }
    }
    
    return result;
}

fn main() -> int {
    return test_nested();
}
