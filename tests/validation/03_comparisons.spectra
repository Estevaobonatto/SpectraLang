// Teste 3: Comparações
module comparisons;

fn test_comparisons() -> bool {
    let x = 10;
    let y = 20;
    
    let lt = x < y;
    let gt = x > y;
    let lte = x <= y;
    let gte = x >= y;
    let eq = x == x;
    let neq = x != y;
    
    return lt && neq;
}

fn main() -> int {
    let result = test_comparisons();
    return 0;
}
