// Teste 16: Break e continue
module break_continue;

fn test_break() -> int {
    let i = 0;
    while i < 100 {
        i = i + 1;
        if i == 10 {
            break;
        }
    }
    return i;
}

fn test_continue() -> int {
    let sum = 0;
    let i = 0;
    
    while i < 10 {
        i = i + 1;
        if i == 5 {
            continue;
        }
        sum = sum + i;
    }
    
    return sum;
}

fn main() -> int {
    let r1 = test_break();
    let r2 = test_continue();
    return r1 + r2;
}
