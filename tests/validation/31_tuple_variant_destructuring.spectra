// Test: Tuple variant destructuring
// Expected: Compile successfully

module test;

enum Option {
    Some(int),
    None
}

enum Result {
    Ok(int),
    Err(int)
}

// Test básico: extrair valor simples
fn test_simple() -> int {
    let opt = Option::Some(42);
    match opt {
        Option::Some(value) => value,
        Option::None => 0
    }
}

// Test: usar valor extraído em expressão
fn test_expression() -> int {
    let opt = Option::Some(10);
    match opt {
        Option::Some(x) => x * 2,
        Option::None => -1
    }
}

// Test: pattern matching aninhado
fn test_result() -> int {
    let res = Result::Ok(100);
    match res {
        Result::Ok(value) => value + 1,
        Result::Err(code) => code * -1
    }
}

fn main() -> int {
    let a = test_simple();    // 42
    let b = test_expression(); // 20
    let c = test_result();    // 101
    
    a + b + c  // 163
}
