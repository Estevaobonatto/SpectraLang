// Teste 14: Múltiplas funções
module multiple_functions;

fn add(a: int, b: int) -> int {
    return a + b;
}

fn multiply(a: int, b: int) -> int {
    return a * b;
}

fn calculate(x: int, y: int) -> int {
    let sum = add(x, y);
    let prod = multiply(x, y);
    return sum + prod;
}

fn main() -> int {
    return calculate(5, 3);
}
