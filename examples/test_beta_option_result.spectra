module test_beta_option_result;

// Beta 0.2: Option<T> e Result<T,E> como tipos built-in
// Não é necessário declarar os enums — eles são registrados globalmente.

fn safe_divide(a: int, b: int) -> Result<int, string> {
    if b == 0 {
        return Result::Err("divisao por zero");
    }
    return Result::Ok(a / b);
}

fn find_positive(x: int) -> Option<int> {
    if x > 0 {
        return Option::Some(x);
    }
    return Option::None;
}

fn main() -> int {
    // ── Option<int> ───────────────────────────────────────────────────────
    let maybe = find_positive(42);
    if let Option::Some(value) = maybe {
        let doubled = value * 2;  // 84
    }

    let nothing = find_positive(-5);
    if let Option::Some(v) = nothing {
        // branch NOT taken
        let x = v + 1;
    }

    // ── Result<int, string> ───────────────────────────────────────────────
    let ok_result = safe_divide(10, 2);
    if let Result::Ok(quotient) = ok_result {
        let check = quotient;  // 5
    }

    let err_result = safe_divide(7, 0);
    if let Result::Err(msg) = err_result {
        // branch taken — msg == "divisao por zero"
        let caught = 1;
    }

    // ── match on Option<int> ──────────────────────────────────────────────
    let answer = match find_positive(4) {
        Option::Some(n) => n,
        Option::None => -1
    };

    // ── while let com Option<int> ─────────────────────────────────────────
    let counter = 3;
    while let Option::Some(n) = find_positive(counter) {
        counter = counter - 1;
    }
    // counter == 0 após loop

    // ── match on Result<int, string> ─────────────────────────────────────
    let r = safe_divide(100, 4);
    let res = match r {
        Result::Ok(v) => v,
        Result::Err(e) => -1
    };

    return 0;
}
