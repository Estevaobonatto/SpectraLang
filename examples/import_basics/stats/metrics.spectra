module stats.metrics;

import calc.arithmetic;

pub fn compute_score(base: int, bonus: int) -> int {
    let boosted = arithmetic.increase(base, bonus);
    let doubled = arithmetic.double(boosted);
    let zero = 0;
    if doubled > 100 {
        return 100;
    }

    if doubled < zero {
        return zero;
    }
    return doubled;
}

pub fn adjust_score(value: int) -> int {
    return arithmetic.half(value);
}
