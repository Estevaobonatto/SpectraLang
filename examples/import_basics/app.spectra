module app;

import calc.arithmetic;
import stats.metrics;
import logging.console;

pub fn main() -> int {
    let base = 40;
    let bonus = 15;
    let score = compute_score(base, bonus);
    let adjusted = adjust_score(score);
    log_number(score);
    log_summary(score, adjusted);
    let final = increase(adjusted, 5);
    return final;
}
