module test_beta_closures;

// Higher-order function that accepts a closure
fn apply(x: int, f: fn(int) -> int) -> int {
    return f(x);
}

fn apply_twice(x: int, f: fn(int) -> int) -> int {
    return f(f(x));
}

fn main() -> int {
    // Basic lambda: |params| body
    let double = |x: int| x * 2;
    let square = |x: int| x * x;
    let add_ten = |x: int| x + 10;

    // Multi-param lambdas
    let add = |a: int, b: int| a + b;
    let mul = |a: int, b: int| a * b;

    // Zero-arg lambda: || body
    let forty_two = || 42;

    // Lambda with block body
    let abs_val = |x: int| {
        if x < 0 {
            return x * -1;
        }
        return x;
    };

    // Passing lambdas to HOFs
    let result1 = apply(5, |x: int| x * 3);
    let result2 = apply_twice(2, |x: int| x + 1);
    let result3 = apply(10, double);

    // Inline lambda in arithmetic
    let val = apply(4, |n: int| n * n) + 1;

    return 0;
}
