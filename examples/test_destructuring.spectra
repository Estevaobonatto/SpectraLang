module test;

enum Option<T> {
    Some(T),
    None
}

fn test_destructuring() -> int {
    let opt = Option::Some(42);
    match opt {
        Option::Some(value) => value,
        Option::None => 0
    }
}

fn test_multiple_values() -> int {
    // Para quando tivermos tuple variants com múltiplos valores
    let x = 10;
    match x {
        _ => x
    }
}

fn test_string_destructuring() -> string {
    let msg = Option::Some("hello");
    match msg {
        Option::Some(text) => text,
        Option::None => "fallback"
    }
}

fn main() -> int {
    let _greeting = test_string_destructuring();
    test_destructuring()
}
