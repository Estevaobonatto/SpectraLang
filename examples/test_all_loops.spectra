module test;

// Test do-while loop with mutable variables
fn test_do_while() -> int {
    let count = 0;
    
    do {
        count = count + 1;
    } while count < 5;
    
    return count;  // Should return 5
}

// Test while loop (C-style for not implemented yet)
fn test_while_as_for() -> int {
    let sum = 0;
    let i = 1;
    
    while i <= 10 {
        sum = sum + i;
        i = i + 1;
    }
    
    return sum;  // Should return 55
}

// Test infinite loop with break
fn test_infinite_loop() -> int {
    let counter = 0;
    
    loop {
        counter = counter + 1;
        
        if counter >= 3 {
            break;
        }
    }
    
    return counter;  // Should return 3
}

// Test nested loops with mutable variables
fn test_nested_loops() -> int {
    let total = 0;
    let i = 0;
    
    while i < 3 {
        let j = 0;
        while j < 4 {
            total = total + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    
    return total;  // Should return 12 (3 * 4)
}

// Test loop with continue
fn test_loop_with_continue() -> int {
    let sum = 0;
    let i = 0;
    
    while i < 10 {
        i = i + 1;
        
        if i % 2 == 0 {
            continue;
        }
        
        sum = sum + i;
    }
    
    return sum;  // Should return 25 (1+3+5+7+9)
}

pub fn main() {
    let r1 = test_do_while();
    let r2 = test_while_as_for();
    let r3 = test_infinite_loop();
    let r4 = test_nested_loops();
    let r5 = test_loop_with_continue();
    
    return;
}
