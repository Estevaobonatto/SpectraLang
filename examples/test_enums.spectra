module test;

// Enum simples (C-style)
enum Color {
    Red,
    Green,
    Blue
}

// Enum com valores associados
enum Option<T> {
    Some(T),
    None
}

enum Result<T> {
    Ok(T),
    Err(T)
}

fn test_simple_enum() -> int {
    let c = Color::Red;
    // Por enquanto, apenas retornar valor fixo
    42
}

fn test_option_enum() -> int {
    let opt = Option::Some(10);
    match opt {
        Option::Some(value) => value,
        Option::None => 0
    }
}

fn test_result_enum() -> int {
    let ok = Result::Ok(21);
    let err = Result::Err(-4);

    let ok_value = match ok {
        Result::Ok(value) => value,
        Result::Err(code) => code,
    };

    let err_value = match err {
        Result::Ok(value) => value,
        Result::Err(code) => code * -1,
    };

    ok_value + err_value
}

fn main() -> int {
    test_simple_enum() + test_option_enum() + test_result_enum()
}
