module test_arrays;

fn test_simple_array() -> int {
    let arr = [1, 2, 3, 4, 5];
    let x = arr[2];
    return x;
}

fn test_array_assignment() -> int {
    let arr = [10, 20, 30];
    arr[1] = 99;
    return arr[1];
}

fn test_array_loop() -> int {
    let arr = [1, 2, 3, 4, 5];
    let sum = 0;
    let i = 0;
    
    while i < 5 {
        sum = sum + arr[i];
        i = i + 1;
    }
    
    return sum;
}
