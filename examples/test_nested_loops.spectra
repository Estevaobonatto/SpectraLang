module test;

// Test nested loops with mutable variables
fn test_nested_loops() -> int {
    let total = 0;
    let i = 0;
    
    while i < 3 {
        let j = 0;
        while j < 4 {
            total = total + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    
    return total;  // Should return 12 (3 * 4)
}

pub fn main() {
    let result = test_nested_loops();
    return;
}
