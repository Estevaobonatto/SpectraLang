// ============================================================
// OOP Test 2 — Operator Overloading (Phase 2)
// Testa: impl Add, Sub, Mul, Eq, Ord para tipos customizados
// ============================================================
module test_oop_operators;

import std.io;

// ─── Vec2D: vetor 2D com aritmética completa ───────────────

struct Vec2D {
    pub x: int,
    pub y: int,
}

impl Vec2D {
    pub fn new(x: int, y: int) -> Vec2D {
        Vec2D { x: x, y: y }
    }

    pub fn length_sq(&self) -> int {
        self.x * self.x + self.y * self.y
    }
}

// v1 + v2
impl Add for Vec2D {
    fn add(&self, other: Vec2D) -> Vec2D {
        Vec2D { x: self.x + other.x, y: self.y + other.y }
    }
}

// v1 - v2
impl Sub for Vec2D {
    fn sub(&self, other: Vec2D) -> Vec2D {
        Vec2D { x: self.x - other.x, y: self.y - other.y }
    }
}

// v1 * v2  (produto escalar como int não faz sentido para Vec2D,
//           então escalamos: Vec2D * Vec2D retorna Vec2D componente a componente)
impl Mul for Vec2D {
    fn mul(&self, other: Vec2D) -> Vec2D {
        Vec2D { x: self.x * other.x, y: self.y * other.y }
    }
}

// v1 == v2
impl Eq for Vec2D {
    fn eq(&self, other: Vec2D) -> bool {
        self.x == other.x && self.y == other.y
    }
}

// ─── Fraction: fração com aritmética e comparação ──────────

struct Fraction {
    pub num: int,   // numerador
    pub den: int,   // denominador (> 0)
}

impl Fraction {
    pub fn new(num: int, den: int) -> Fraction {
        Fraction { num: num, den: den }
    }

    // Retorna numerador * 1000 / denominador como proxy de valor real
    pub fn approx(&self) -> int {
        self.num * 1000 / self.den
    }
}

// (a/b) + (c/d) = (ad + bc) / bd
impl Add for Fraction {
    fn add(&self, other: Fraction) -> Fraction {
        Fraction {
            num: self.num * other.den + other.num * self.den,
            den: self.den * other.den,
        }
    }
}

// (a/b) - (c/d) = (ad - bc) / bd
impl Sub for Fraction {
    fn sub(&self, other: Fraction) -> Fraction {
        Fraction {
            num: self.num * other.den - other.num * self.den,
            den: self.den * other.den,
        }
    }
}

// (a/b) * (c/d) = ac / bd
impl Mul for Fraction {
    fn mul(&self, other: Fraction) -> Fraction {
        Fraction {
            num: self.num * other.num,
            den: self.den * other.den,
        }
    }
}

// a/b == c/d  ⟺  ad == bc
impl Eq for Fraction {
    fn eq(&self, other: Fraction) -> bool {
        self.num * other.den == other.num * self.den
    }
}

// a/b < c/d  ⟺  ad < bc
impl Ord for Fraction {
    fn lt(&self, other: Fraction) -> bool {
        self.num * other.den < other.num * self.den
    }
    fn le(&self, other: Fraction) -> bool {
        self.num * other.den <= other.num * self.den
    }
    fn gt(&self, other: Fraction) -> bool {
        self.num * other.den > other.num * self.den
    }
    fn ge(&self, other: Fraction) -> bool {
        self.num * other.den >= other.num * self.den
    }
}

pub fn main() -> int {
    // ── Vec2D ─────────────────────────────────────────────────
    let a = Vec2D::new(1, 2);
    let b = Vec2D::new(3, 4);

    let sum_v = a + b;          // (4, 6)
    println(f"Vec2D soma: ({sum_v.x}, {sum_v.y})");

    let diff_v = b - a;         // (2, 2)
    println(f"Vec2D diff: ({diff_v.x}, {diff_v.y})");

    let prod_v = a * b;         // (3, 8)
    println(f"Vec2D prod: ({prod_v.x}, {prod_v.y})");

    let eq_v = a == a;          // true
    let neq_v = a == b;         // false
    println(f"Vec2D a==a: {eq_v}");
    println(f"Vec2D a==b: {neq_v}");

    // ── Fraction ──────────────────────────────────────────────
    let half  = Fraction::new(1, 2);   // 1/2
    let third = Fraction::new(1, 3);   // 1/3

    let sum_f = half + third;           // 5/6
    println(f"1/2 + 1/3 = {sum_f.num}/{sum_f.den}");

    let diff_f = half - third;          // 1/6
    println(f"1/2 - 1/3 = {diff_f.num}/{diff_f.den}");

    let prod_f = half * third;          // 1/6
    println(f"1/2 * 1/3 = {prod_f.num}/{prod_f.den}");

    let lt_r = third < half;            // true: 1/3 < 1/2
    let gt_r = half > third;            // true
    let eq_r = half == Fraction::new(2, 4);  // true: 1/2 == 2/4
    println(f"1/3 < 1/2: {lt_r}");
    println(f"1/2 > 1/3: {gt_r}");
    println(f"1/2 == 2/4: {eq_r}");

    return 0;
}
