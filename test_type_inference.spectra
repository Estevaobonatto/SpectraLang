// Test type inference for generic structs

module test_type_inference;

struct Point<T> {
    x: T,
    y: T
}

struct Pair<T, U> {
    first: T,
    second: U
}

fn main() -> int {
    // Type inference: should infer Point<int>
    let p1 = Point { x: 10, y: 20 };
    
    // Type inference: should infer Point<float>
    let p2 = Point { x: 3.14, y: 2.71 };
    
    // Type inference: should infer Pair<int, float>
    let pair = Pair { first: 42, second: 1.5 };
    
    // Explicit types still work
    let p3 = Point<int> { x: 100, y: 200 };
    
    // Test that inferred types work with field access
    return p1.x + p1.y; // Should return 30
}
