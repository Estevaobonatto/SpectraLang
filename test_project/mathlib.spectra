module mathlib;

// Basic math utilities

pub fn square(n: int) -> int {
    return n * n;
}

pub fn cube(n: int) -> int {
    return n * n * n;
}

pub fn factorial(n: int) -> int {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

pub fn max(a: int, b: int) -> int {
    if a > b {
        return a;
    }
    return b;
}

pub fn min(a: int, b: int) -> int {
    if a < b {
        return a;
    }
    return b;
}

pub fn abs_val(n: int) -> int {
    if n < 0 {
        return n * -1;
    }
    return n;
}
